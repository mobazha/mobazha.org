---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Mobazha Blog`} description={post.data.description}>
  <Header />
  <main class="pt-32 pb-20">
    <article class="mx-auto max-w-3xl px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-body)]">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        Back to Blog
      </a>

      <header class="mt-8">
        <time class="text-sm font-medium text-[var(--color-text-muted)]">
          {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
          {post.data.title}
        </h1>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">By {post.data.author}</p>
      </header>

      <div class="prose-invert mt-10 max-w-none [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-[var(--color-text-primary)] [&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-[var(--color-text-primary)] [&_p]:mt-4 [&_p]:leading-relaxed [&_p]:text-[var(--color-text-body)] [&_a]:text-[var(--color-brand-light)] [&_a]:underline [&_a]:underline-offset-4 hover:[&_a]:text-[var(--color-brand)] [&_ul]:mt-4 [&_ul]:space-y-2 [&_ul]:pl-6 [&_li]:text-[var(--color-text-body)] [&_li]:marker:text-[var(--color-brand-light)] [&_strong]:text-[var(--color-text-primary)] [&_hr]:my-8 [&_hr]:border-white/10 [&_em]:text-[var(--color-text-muted)] [&_blockquote]:border-l-2 [&_blockquote]:border-[var(--color-brand)]/30 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-[var(--color-text-muted)]">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</Layout>
