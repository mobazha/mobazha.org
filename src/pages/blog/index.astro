---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog - Mobazha" description="Latest news, updates, and stories from the Mobazha team.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text-primary)]">Blog</h1>
      <p class="mt-4 text-lg text-[var(--color-text-body)]">
        News, updates, and stories from the Mobazha team.
      </p>

      {posts.length === 0 ? (
        <div class="mt-16 rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-12 text-center">
          <p class="text-lg text-[var(--color-text-muted)]">Coming soon. Stay tuned.</p>
          <a href="https://t.me/mobazha" class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-brand-light)] transition-colors hover:text-[var(--color-brand)]">
            Follow us on Telegram for updates
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </div>
      ) : (
        <div class="mt-12 space-y-8">
          {posts.map(post => (
            <a
              href={`/blog/${post.id}`}
              class="block rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-6 transition-all hover:border-[var(--color-brand)]/20 hover:shadow-lg hover:shadow-[var(--color-glow)]"
            >
              <time class="text-xs font-medium text-[var(--color-text-muted)]">
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="mt-2 text-xl font-semibold text-[var(--color-text-primary)]">{post.data.title}</h2>
              <p class="mt-2 text-sm text-[var(--color-text-body)]">{post.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
