---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  getSellerComparisonCryptoLabel,
  getCryptoPaymentsFootnote,
  getCryptoRequiredFaqAnswer,
} from '../config/paymentVisibility';

const comparisonCryptoLabel = getSellerComparisonCryptoLabel();
const cryptoPaymentsFootnote = getCryptoPaymentsFootnote();
const cryptoRequiredFaqAnswer = getCryptoRequiredFaqAnswer();

const benefits = [
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Protect your margin',
    description: 'Independent Community operation has no mandatory central Mobazha transaction fee. Managed services, network costs, and third-party fees are disclosed separately.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>`,
    title: 'Understand settlement risk',
    description: 'On-chain settlement does not use the card chargeback mechanism, but refunds, disputes, fraud, and compliance risk still exist. Each order follows explicit settlement terms.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>`,
    title: 'Reduce platform dependency',
    description: 'Export your data or run Community software on infrastructure you control. Hosted services and public networks still have policies, availability limits, and legal obligations.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>`,
    title: 'Sell inside Telegram',
    description: 'Your store lives as a Mini App. Share the link in any chat or group — buyers browse and check out without leaving Telegram. Your audience, your store, one tap away.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Complete data ownership',
    description: 'Your products, orders, and customers are yours. No tracking, no data mining, no algorithms hiding your store from buyers. Export everything at any time.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: 'AI-powered seller tools',
    description: 'Quick Create turns a photo into a polished listing in 60 seconds. AI Store Builder designs your storefront. Your AI assistant handles product descriptions, pricing, and more.',
  },
];

const personas = [
  {
    emoji: '📱',
    title: 'Telegram community owners',
    description: 'You run a channel, group, or community. Turn your audience into customers without sending them away.',
  },
  {
    emoji: '📚',
    title: 'Digital creators',
    description: 'Sell ebooks, courses, software, or digital art with clear delivery, settlement, refund, and dispute terms.',
  },
  {
    emoji: '🎨',
    title: 'Independent crafters & artists',
    description: 'Tired of Etsy taking 6.5% plus payment fees. Keep your margins, own your brand, own your customer list.',
  },
  {
    emoji: '🛡',
    title: 'Privacy-conscious merchants',
    description: 'You value privacy and control. Self-host with an optional privacy overlay while still following applicable payment, tax, and legal requirements.',
  },
];
---

<Layout title="For Sellers - Mobazha" description="Open commerce tools for independent sellers who want portable data, flexible deployment, and fees disclosed before use.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-[var(--color-brand)] opacity-[0.06] blur-[100px]"></div>
      </div>
      <div class="relative">
        <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
          Keep control of your business.<br />
          <span class="bg-gradient-to-r from-[var(--color-brand)] to-[var(--color-brand-light)] bg-clip-text text-transparent">
            On your terms.
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-body)]">
          Own your customer relationship, choose how you deploy, and see applicable service and network costs before confirming a transaction.
        </p>
      </div>
    </div>

    <!-- Platform comparison -->
    <div class="mx-auto mt-20 max-w-5xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)]">
          How Mobazha compares
        </h2>
        <p class="mt-3 text-[var(--color-text-body)]">
          Portable data, flexible deployment, and transparent service boundaries.
        </p>
      </div>

      <div class="mt-10 overflow-x-auto rounded-2xl border border-white/5 bg-[var(--color-bg-surface)]">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="py-4 pl-6 pr-6 font-medium text-[var(--color-text-muted)]"></th>
              <th class="py-4 pr-6 font-semibold text-[var(--color-brand-light)]">Mobazha</th>
              <th class="py-4 pr-6 font-medium text-[var(--color-text-muted)]">Shopify</th>
              <th class="py-4 pr-6 font-medium text-[var(--color-text-muted)]">Etsy</th>
              <th class="py-4 pr-6 font-medium text-[var(--color-text-muted)]">Amazon</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-text-body)]">
            <tr class="border-b border-white/5">
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Platform and service fees</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Separated by service</td>
              <td class="py-3 pr-6">Varies by plan</td>
              <td class="py-3 pr-6">Varies by category</td>
              <td class="py-3 pr-6">Varies by category</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Chargeback risk</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Payment-dependent</td>
              <td class="py-3 pr-6">Yes</td>
              <td class="py-3 pr-6">Yes</td>
              <td class="py-3 pr-6">Yes</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Data ownership</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Exportable / self-hostable</td>
              <td class="py-3 pr-6">Platform-hosted</td>
              <td class="py-3 pr-6">Platform-owned</td>
              <td class="py-3 pr-6">Platform-owned</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Self-hosting</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Yes (Native &amp; Docker)</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Telegram Mini App</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Native</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
            </tr>
            <tr>
              <td class="py-3 pl-6 pr-6 text-[var(--color-text-muted)]">Crypto payments</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">{comparisonCryptoLabel}</td>
              <td class="py-3 pr-6">Plugin</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-[var(--color-text-muted)]">
        {cryptoPaymentsFootnote}
      </p>
    </div>

    <!-- Benefits grid -->
    <div class="mx-auto mt-24 max-w-6xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)]">
          Built around what sellers actually need
        </h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(benefit => (
          <div class="rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-8">
            <div class="mb-5 text-[var(--color-brand-light)]">
              <Fragment set:html={benefit.icon} />
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Seller Dashboard showcase -->
    <div class="mx-auto mt-24 max-w-6xl px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-brand)]/20 bg-[var(--color-brand)]/10 px-3 py-1 text-xs font-medium uppercase tracking-wide text-[var(--color-brand-light)]">
            Seller dashboard
          </div>
          <h2 class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-text-primary)]">
            Run your whole business from one screen
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-[var(--color-text-body)]">
            A complete admin for independent sellers — products, orders, discounts, analytics, storefront design. All in one place, all under your control.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-body)]">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <span><strong class="text-[var(--color-text-primary)]">Quick Create</strong> — turn a photo into a polished listing in 60 seconds with AI</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-body)]">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <span><strong class="text-[var(--color-text-primary)]">Storefront designer</strong> — customize branding, layout, and theme visually</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-body)]">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <span><strong class="text-[var(--color-text-primary)]">Analytics</strong> — track sales, top products, customer behavior</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-body)]">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <span><strong class="text-[var(--color-text-primary)]">Discounts & collections</strong> — run promotions, curate product groups</span>
            </li>
          </ul>
        </div>
        <div class="relative">
          <div class="overflow-hidden rounded-xl border border-white/10 shadow-2xl shadow-black/50">
            <img
              src="/images/admin_dark.png"
              alt="Mobazha seller dashboard — products, orders, analytics, and AI tools"
              class="block w-full"
              width="1024"
              height="768"
              loading="lazy"
            />
          </div>
          <div class="pointer-events-none absolute -inset-4 rounded-2xl bg-[var(--color-brand)] opacity-[0.04] blur-3xl"></div>
        </div>
      </div>
    </div>

    <!-- Personas -->
    <div class="mx-auto mt-24 max-w-6xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)]">
          Who builds on Mobazha
        </h2>
        <p class="mt-3 text-[var(--color-text-body)]">
          Independent sellers who put control, privacy, and margin above convenience.
        </p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {personas.map(persona => (
          <div class="rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-8">
            <div class="text-3xl">{persona.emoji}</div>
            <h3 class="mt-4 text-lg font-semibold text-[var(--color-text-primary)]">{persona.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{persona.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Decision FAQ -->
    <div class="mx-auto mt-24 max-w-3xl px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-[var(--color-text-primary)]">
        Is Mobazha right for me?
      </h2>
      <div class="mt-10 space-y-4">
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            Do I need to accept crypto?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            {cryptoRequiredFaqAnswer}
          </div>
        </details>
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            I already sell on Shopify / Etsy. Why switch?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            You don't have to. Most sellers start Mobazha as a second channel — especially for crypto-native buyers or their existing Telegram audience. If it outgrows your other channels, migrate your catalog over (all data is portable).
          </div>
        </details>
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            How do I get traffic on a new platform?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            Mobazha is a <strong>distribution layer</strong>, not another marketplace that waits for shoppers. Your store is a Telegram Mini App — share the link where your customers already are (groups, channels, social posts, QR codes). You bring the audience, we make checkout trivial.
          </div>
        </details>
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            What happens if a buyer disputes an order?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            Supported escrow orders follow the payment method and order terms shown at checkout. A dispute may require evidence and human review. On-chain settlement avoids the card chargeback mechanism, but it does not eliminate refunds, fraud, operational mistakes, or legal obligations.
          </div>
        </details>
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            SaaS or self-hosted — which should I pick?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            <strong>SaaS</strong> — ready in 30 seconds, we handle hosting and updates. Works for 90% of sellers.<br/>
            <strong>Self-hosted</strong> — you run it on your own box for maximum data sovereignty or privacy (Tor / Lokinet overlay). You can migrate between them at any time.
          </div>
        </details>
        <details class="group rounded-xl border border-white/5 bg-[var(--color-bg-surface)]">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium text-[var(--color-text-primary)]">
            Is it really free? What's the catch?
            <svg class="h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="border-t border-white/5 px-6 py-4 text-sm text-[var(--color-text-body)]">
            Mobazha Cloud currently has no subscription charge during Beta. That is a current Beta policy, not a permanent promise. Independent Community operation has no mandatory central Mobazha transaction fee; servers, networks, third parties, and optional managed services can still cost money. See <a class="text-[var(--color-brand-light)] hover:underline" href="/fees">Fees and Paid Services</a>.
          </div>
        </details>
      </div>
    </div>

    <!-- CTA -->
    <div class="mx-auto mt-24 max-w-3xl px-6 text-center lg:px-8">
      <h2 class="text-3xl font-bold text-[var(--color-text-primary)]">
        Start selling on your terms
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-body)]">
        Start with the current Cloud Beta or run the Community software yourself. Review fees and operating costs before choosing services.
      </p>
