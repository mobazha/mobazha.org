---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Complete Data Ownership',
    description: 'Your store data lives on your terms. No tracking, no data mining, no algorithms deciding your visibility. Export everything at any time.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>`,
    title: 'Self-Hosted Option',
    description: 'Run your store on your own server with our Docker image. Complete independence from any platform. Your VPS, your rules.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>`,
    title: 'Zero Platform Risk',
    description: 'No arbitrary account suspensions. No algorithm changes tanking your sales. No surprise fee increases. You are not at the mercy of a platform.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: 'Built-in Trust',
    description: 'Automatic payment protection on every transaction. Buyers trust your store from day one without you needing years of reviews or a big brand name.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: '100% of Your Revenue',
    description: 'Sell $1,000 and keep $1,000. Zero transaction fees, zero commissions. The most seller-friendly pricing in e-commerce.',
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>`,
    title: 'Sell Where Your Customers Are',
    description: 'Your store lives inside Telegram as a Mini App. Share in any chat or group. Customers browse and buy without ever leaving the app.',
  },
];
---

<Layout title="For Sellers - Mobazha" description="Complete data ownership. Zero commissions. Self-host your store. Built for independent sellers who value privacy and control.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-[var(--color-brand)] opacity-[0.06] blur-[100px]"></div>
      </div>
      <div class="relative">
        <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
          Your Store. Your Data.<br />
          <span class="bg-gradient-to-r from-[var(--color-brand)] to-[var(--color-brand-light)] bg-clip-text text-transparent">
            Your Rules.
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-body)]">
          Mobazha gives independent sellers complete control. No middlemen taking a cut.
          No algorithms deciding who sees your products. No platform lock-in.
        </p>
      </div>
    </div>

    <!-- Benefits grid -->
    <div class="mx-auto mt-20 max-w-6xl px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map(benefit => (
          <div class="rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-8">
            <div class="mb-5 text-[var(--color-brand-light)]">
              <Fragment set:html={benefit.icon} />
            </div>
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Comparison -->
    <div class="mx-auto mt-24 max-w-4xl px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold text-[var(--color-text-primary)]">
        How Mobazha compares
      </h2>
      <div class="mt-10 overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="pb-4 pr-6 font-medium text-[var(--color-text-muted)]"></th>
              <th class="pb-4 pr-6 font-semibold text-[var(--color-brand-light)]">Mobazha</th>
              <th class="pb-4 pr-6 font-medium text-[var(--color-text-muted)]">Shopify</th>
              <th class="pb-4 pr-6 font-medium text-[var(--color-text-muted)]">Etsy</th>
              <th class="pb-4 font-medium text-[var(--color-text-muted)]">Amazon</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-text-body)]">
            <tr class="border-b border-white/5">
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Commission</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">0%</td>
              <td class="py-3 pr-6">0.5-2%</td>
              <td class="py-3 pr-6">6.5%</td>
              <td class="py-3">8-15%</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Monthly Fee</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">$0 (Free tier)</td>
              <td class="py-3 pr-6">$39+</td>
              <td class="py-3 pr-6">$0.20/listing</td>
              <td class="py-3">$39.99</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Data Ownership</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">100% yours</td>
              <td class="py-3 pr-6">Platform-hosted</td>
              <td class="py-3 pr-6">Platform-owned</td>
              <td class="py-3">Platform-owned</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Self-Hosting</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Yes (Docker)</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3">No</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Buyer Protection</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Smart Contract Escrow</td>
              <td class="py-3 pr-6">Chargeback</td>
              <td class="py-3 pr-6">Platform mediation</td>
              <td class="py-3">A-to-Z Guarantee</td>
            </tr>
            <tr>
              <td class="py-3 pr-6 text-[var(--color-text-muted)]">Crypto Payments</td>
              <td class="py-3 pr-6 font-semibold text-[var(--color-brand-light)]">Native (6 chains)</td>
              <td class="py-3 pr-6">Plugin</td>
              <td class="py-3 pr-6">No</td>
              <td class="py-3">No</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA -->
    <div class="mx-auto mt-24 max-w-3xl px-6 text-center lg:px-8">
      <h2 class="text-3xl font-bold text-[var(--color-text-primary)]">
        Start selling on your terms
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-body)]">
        Create your store in 30 seconds. All features free during Beta.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://app.mobazha.org"
          class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-cta)] px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-[var(--color-cta)]/25 transition-all hover:bg-[var(--color-cta-hover)] hover:shadow-xl"
        >
          Create Your Store
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a
          href="/pricing"
          class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-7 py-3.5 text-base font-medium text-[var(--color-text-primary)] transition-all hover:border-white/20 hover:bg-white/10"
        >
          View Pricing
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
