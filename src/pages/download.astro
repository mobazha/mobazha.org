---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const VERSION = 'v0.3.0-beta.17';
const TAG = `native-${VERSION}`;
const BASE = `https://github.com/mobazha/mobazha.org/releases/download/${TAG}`;

const platforms = {
  windows: {
    label: 'Windows',
    detail: 'Windows 10+ (x86_64)',
    file: `Mobazha-${VERSION}-windows-amd64.zip`,
    ext: '.zip',
  },
};

const cliPlatforms = [
  { os: 'Linux x86_64', cmd: 'curl -sSL https://get.mobazha.org/install | bash' },
  { os: 'Linux ARM64', cmd: 'curl -sSL https://get.mobazha.org/install | bash' },
  { os: 'macOS (CLI)', cmd: 'curl -sSL https://get.mobazha.org/install | bash' },
];
---

<Layout title="Download Mobazha - Run Your Own Store" description="Install Mobazha on your computer. Desktop tray for macOS and Windows, CLI for all platforms. No server required.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <div class="relative mx-auto max-w-3xl px-6 text-center lg:px-8">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-[var(--color-brand)] opacity-[0.06] blur-[100px]"></div>
      </div>
      <div class="relative">
        <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
          Download Mobazha
        </h1>
        <p class="mx-auto mt-4 max-w-xl text-lg text-[var(--color-text-body)]">
          Run your own store on your computer. One command to install, then a visual desktop experience — no server needed.
        </p>
      </div>
    </div>

    <!-- Primary download (OS-detected) -->
    <div class="mx-auto mt-12 max-w-xl px-6 lg:px-8">
      <div id="detected-download" class="rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-bg-surface)] p-8 text-center">
        <div id="os-icon" class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-[var(--color-brand)]/10">
          <svg class="h-8 w-8 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
        </div>
        <p id="detected-label" class="text-sm font-medium text-[var(--color-text-muted)] mb-2">Recommended for your system</p>

        <!-- macOS (curl installs CLI + tray) -->
        <div id="dl-mac-arm" class="dl-section">
          <div class="rounded-xl bg-[var(--color-bg-base)] px-5 py-4 font-mono text-sm">
            <span class="select-none text-[var(--color-text-muted)]">$ </span>
            <code class="text-[var(--color-brand-light)]">curl -sSL https://get.mobazha.org/install | bash</code>
          </div>
          <p class="mt-3 text-sm text-[var(--color-text-muted)]">
            Apple Silicon &amp; Intel. Installs CLI + desktop tray. Run <code>mobazha-tray</code> for a visual experience.
          </p>
        </div>

        <!-- Windows -->
        <div id="dl-windows" class="dl-section hidden">
          <a
            href={`${BASE}/${platforms.windows.file}`}
            class="inline-flex items-center gap-3 rounded-xl bg-[var(--color-cta)] px-8 py-4 text-base font-semibold text-white shadow-lg shadow-[var(--color-cta)]/25 transition-all hover:bg-[var(--color-cta-hover)] hover:shadow-xl"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
            Download for Windows
          </a>
          <p class="mt-3 text-sm text-[var(--color-text-muted)]">
            Windows 10+ ({platforms.windows.ext}) &middot; Extract and double-click <code>mobazha-tray.exe</code>
          </p>
        </div>

        <!-- Linux / fallback -->
        <div id="dl-linux" class="dl-section hidden">
          <div class="rounded-xl bg-[var(--color-bg-base)] px-5 py-4 font-mono text-sm">
            <span class="select-none text-[var(--color-text-muted)]">$ </span>
            <code class="text-[var(--color-brand-light)]">curl -sSL https://get.mobazha.org/install | bash</code>
          </div>
          <p class="mt-3 text-sm text-[var(--color-text-muted)]">
            Single binary, zero dependencies. x86_64 &amp; ARM64.
          </p>
        </div>

        <p class="mt-4 text-xs text-[var(--color-text-muted)]">
          {VERSION} &middot;
          <a href={`https://github.com/mobazha/mobazha.org/releases/tag/${TAG}`} target="_blank" rel="noopener noreferrer" class="text-[var(--color-brand-light)] hover:underline">Release notes</a>
        </p>
      </div>
    </div>

    <!-- All platforms grid -->
    <div class="mx-auto mt-16 max-w-3xl px-6 lg:px-8">
      <h2 class="text-center text-xl font-bold text-[var(--color-text-primary)] mb-8">All Platforms</h2>

      <div class="grid gap-4 sm:grid-cols-3">
        <!-- Windows Desktop -->
        <div class="rounded-xl border border-white/5 bg-[var(--color-bg-surface)] p-5">
          <div class="mb-3 flex items-center gap-2">
            <svg class="h-5 w-5 text-[var(--color-text-muted)]" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
            <span class="font-semibold text-[var(--color-text-primary)]">Windows</span>
          </div>
          <div class="space-y-2">
            <a href={`${BASE}/${platforms.windows.file}`} class="flex items-center justify-between rounded-lg bg-[var(--color-bg-base)] px-3 py-2 text-sm transition-colors hover:bg-white/5">
              <span class="text-[var(--color-text-body)]">Desktop (x86_64)</span>
              <span class="text-xs text-[var(--color-brand-light)]">.zip</span>
            </a>
          </div>
        </div>

        <!-- macOS CLI -->
        <div class="rounded-xl border border-white/5 bg-[var(--color-bg-surface)] p-5">
          <div class="mb-3 flex items-center gap-2">
            <svg class="h-5 w-5 text-[var(--color-text-muted)]" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="font-semibold text-[var(--color-text-primary)]">macOS</span>
          </div>
          <div class="space-y-2">
            <a href={`${BASE}/mobazha-darwin-arm64`} class="flex items-center justify-between rounded-lg bg-[var(--color-bg-base)] px-3 py-2 text-sm transition-colors hover:bg-white/5">
              <span class="text-[var(--color-text-body)]">Apple Silicon</span>
              <span class="text-xs text-[var(--color-brand-light)]">CLI</span>
            </a>
            <a href={`${BASE}/mobazha-darwin-amd64`} class="flex items-center justify-between rounded-lg bg-[var(--color-bg-base)] px-3 py-2 text-sm transition-colors hover:bg-white/5">
              <span class="text-[var(--color-text-body)]">Intel</span>
              <span class="text-xs text-[var(--color-brand-light)]">CLI</span>
            </a>
          </div>
        </div>

        <!-- Linux CLI -->
        <div class="rounded-xl border border-white/5 bg-[var(--color-bg-surface)] p-5">
          <div class="mb-3 flex items-center gap-2">
            <svg class="h-5 w-5 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>
            <span class="font-semibold text-[var(--color-text-primary)]">Linux</span>
          </div>
          <div class="space-y-2">
            <a href={`${BASE}/mobazha-linux-amd64`} class="flex items-center justify-between rounded-lg bg-[var(--color-bg-base)] px-3 py-2 text-sm transition-colors hover:bg-white/5">
              <span class="text-[var(--color-text-body)]">x86_64</span>
              <span class="text-xs text-[var(--color-brand-light)]">CLI</span>
            </a>
            <a href={`${BASE}/mobazha-linux-arm64`} class="flex items-center justify-between rounded-lg bg-[var(--color-bg-base)] px-3 py-2 text-sm transition-colors hover:bg-white/5">
              <span class="text-[var(--color-text-body)]">ARM64</span>
              <span class="text-xs text-[var(--color-brand-light)]">CLI</span>
            </a>
          </div>
        </div>
      </div>

      <p class="mt-6 text-center text-sm text-[var(--color-text-muted)]">
        Looking for Docker or VPS deployment? <a href="/self-host" class="text-[var(--color-brand-light)] hover:underline">Self-Host guide</a>
      </p>
    </div>

    <!-- What's included -->
    <div class="mx-auto mt-20 max-w-3xl px-6 lg:px-8">
      <h2 class="text-center text-xl font-bold text-[var(--color-text-primary)] mb-8">How It Works</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">1</div>
          <h3 class="font-semibold text-[var(--color-text-primary)]">Install</h3>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">Run the install command (macOS/Linux) or extract the .zip (Windows). No dependencies.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">2</div>
          <h3 class="font-semibold text-[var(--color-text-primary)]">Launch</h3>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">Run <code>mobazha-tray</code>. A tray icon appears and your browser opens automatically.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">3</div>
          <h3 class="font-semibold text-[var(--color-text-primary)]">Start Selling</h3>
          <p class="mt-1 text-sm text-[var(--color-text-muted)]">Set your password, add products, and share your store link.</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mx-auto mt-16 max-w-xl px-6 text-center lg:px-8">
      <p class="text-[var(--color-text-body)]">
        Prefer a hosted solution? <a href="https://app.mobazha.org" class="font-semibold text-[var(--color-brand-light)] hover:underline">Create a free SaaS store</a> — no download needed.
      </p>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  function detectOS() {
    const ua = navigator.userAgent;
    if (/Mac/i.test(ua)) return 'mac';
    if (/Win/i.test(ua)) return 'windows';
    if (/Linux/i.test(ua)) return 'linux';
    return 'mac';
  }

  const os = detectOS();
  const sections = document.querySelectorAll('.dl-section');
  sections.forEach(s => s.classList.add('hidden'));

  const sectionMap: Record<string, string> = {
    windows: 'dl-windows',
    linux: 'dl-linux',
    mac: 'dl-mac-arm',
  };
  const active = document.getElementById(sectionMap[os] || 'dl-linux');
  active?.classList.remove('hidden');

  const label = document.getElementById('detected-label');
  if (label) {
    const labels: Record<string, string> = {
      mac: 'Detected: macOS',
      windows: 'Detected: Windows',
      linux: 'Detected: Linux',
    };
    label.textContent = labels[os] || 'Recommended for your system';
  }
</script>
