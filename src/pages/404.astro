---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - Mobazha">
  <Header />
  <main class="flex min-h-[60vh] items-center justify-center pt-20">
    <div class="px-6 text-center">
      <p class="text-7xl font-bold text-[var(--color-brand)]">404</p>
      <h1 class="mt-4 text-2xl font-bold text-[var(--color-text-primary)]">Page not found</h1>
      <p class="mt-2 text-[var(--color-text-muted)]">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 rounded-xl bg-[var(--color-cta)] px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-cta-hover)]"
      >
        Go Home
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </main>
  <Footer />
</Layout>
