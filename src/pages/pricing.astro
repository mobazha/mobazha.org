---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { economicsPolicy } from '../config/economics';

const offers = [
  {
    name: 'Community',
    eyebrow: 'Self-hosted',
    price: 'Open source',
    period: '',
    description: 'Run the Community software on infrastructure you control.',
    features: [
      'No mandatory central Mobazha transaction fee',
      'Your server, data, and operating choices',
      'Community payment capabilities and updates',
      'You pay infrastructure and network costs',
      'Optional services and plugins priced separately',
    ],
    cta: 'Explore Self-Hosting',
    ctaHref: '/self-host',
    highlighted: false,
  },
  {
    name: 'Mobazha Cloud',
    eyebrow: 'Current Beta',
    price: '$0',
    period: ' subscription fee during Beta',
    description: 'Start a managed store without running a server.',
    features: [
      'No subscription charge during the current Beta',
      'Managed hosting and updates',
      'Store administration and buyer checkout',
      'Beta limits and availability may change',
      'Future pricing published before it applies',
    ],
    cta: 'Create Your Store',
    ctaHref: 'https://app.mobazha.org',
    highlighted: true,
  },
  {
    name: 'Managed Services',
    eyebrow: 'Pilot',
    price: 'Quoted',
    period: ' before use',
    description: 'Use only the transaction, distribution, or support services you need.',
    features: [
      'Managed transaction and delivery workflows',
      'Evidence and dispute operations where offered',
      'Optional referral or distribution budgets',
      'AI, storage, support, and other add-ons',
      'Payer and fee disclosed before confirmation',
    ],
    cta: 'How Fees Work',
    ctaHref: economicsPolicy.feesPath,
    highlighted: false,
  },
];
---

<Layout title="Pricing - Mobazha" description="Current Mobazha Community, Cloud Beta, and managed-service pricing status.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-brand)]/5 p-6 text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand)]/10 px-4 py-1.5">
          <span class="h-2 w-2 animate-pulse rounded-full bg-[var(--color-brand-light)]"></span>
          <span class="text-sm font-semibold text-[var(--color-brand-light)]">{economicsPolicy.stage}</span>
        </div>
        <h2 class="mt-3 text-2xl font-bold text-[var(--color-text-primary)]">
          Mobazha Cloud currently has no subscription charge
        </h2>
        <p class="mt-2 text-[var(--color-text-body)]">
          {economicsPolicy.currentStatus.cloud}
        </p>
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-3xl px-6 text-center lg:px-8">
      <h1 class="text-4xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
        Choose who operates the service
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-body)]">
        Self-host the open-source Community software, use Mobazha Cloud, or add managed services when they create value. Charges are separated and disclosed before use.
      </p>
      <p class="mt-3 text-xs text-[var(--color-text-muted)]">Policy effective {economicsPolicy.effectiveDate}</p>
    </div>

    <div class="mx-auto mt-14 grid max-w-6xl gap-6 px-6 md:grid-cols-3 lg:px-8">
      {offers.map(offer => (
        <div class:list={[
          'relative flex flex-col rounded-2xl border p-7',
          offer.highlighted
            ? 'border-[var(--color-brand)]/40 bg-[var(--color-bg-surface)] shadow-lg shadow-[var(--color-glow)]'
            : 'border-white/5 bg-[var(--color-bg-surface)]',
        ]}>
          {offer.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-[var(--color-brand)] to-[var(--color-brand-light)] px-3 py-0.5 text-xs font-semibold text-white">
              Fastest start
            </div>
          )}
          <div class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-light)]">{offer.eyebrow}</div>
          <h2 class="mt-2 text-xl font-semibold text-[var(--color-text-primary)]">{offer.name}</h2>
          <p class="mt-2 min-h-12 text-sm text-[var(--color-text-muted)]">{offer.description}</p>
          <div class="mt-6">
            <span class="text-3xl font-bold text-[var(--color-text-primary)]">{offer.price}</span>
            <span class="text-sm text-[var(--color-text-muted)]">{offer.period}</span>
          </div>
          <ul class="mt-6 flex-1 space-y-3">
            {offer.features.map(feature => (
              <li class="flex items-start gap-2 text-sm text-[var(--color-text-body)]">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <a
            href={offer.ctaHref}
            class:list={[
              'mt-7 block rounded-lg py-2.5 text-center text-sm font-semibold transition-colors',
              offer.highlighted
                ? 'bg-[var(--color-cta)] text-white hover:bg-[var(--color-cta-hover)]'
                : 'border border-white/10 text-[var(--color-text-primary)] hover:bg-white/5',
            ]}
          >
            {offer.cta}
          </a>
        </div>
      ))}
    </div>

    <section class="mx-auto mt-16 max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-white/10 bg-[var(--color-bg-surface)] p-8 sm:p-10">
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)]">Why there is no single “Mobazha fee”</h2>
        <p class="mt-3 text-[var(--color-text-body)]">
          Software, hosting, managed transaction work, optional distribution, and blockchain or payment-provider costs are different things. Combining them into one commission percentage would hide who provides the service and who receives the money.
        </p>
        <a href={economicsPolicy.feesPath} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-light)] hover:underline">
          Read the fees and paid services policy
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-3xl px-6 text-center lg:px-8">
      <h2 class="text-2xl font-bold text-[var(--color-text-primary)]">Pricing will follow evidence, not slogans</h2>
      <p class="mt-3 text-[var(--color-text-body)]">
        Subscription and managed-service prices remain under validation. We will publish the service, payer, amount, effective date, and refund treatment before a new charge applies.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
