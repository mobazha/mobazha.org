---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { economicsPolicy } from '../config/economics';

const categories = [
  {
    title: 'Community self-hosting',
    status: 'No mandatory Mobazha transaction fee',
    description: economicsPolicy.currentStatus.community,
  },
  {
    title: 'Mobazha Cloud',
    status: 'No subscription charge during the current Beta',
    description: economicsPolicy.currentStatus.cloud,
  },
  {
    title: 'Managed transactions',
    status: 'Pilot — quoted before use',
    description: economicsPolicy.currentStatus.managedTransactions,
  },
  {
    title: 'Distribution and referrals',
    status: 'Optional and seller-funded',
    description:
      'A seller may choose to fund an attributable referral, curator, or agent. These arrangements are separate from the base platform fee and should be disclosed to the parties involved.',
  },
];
---

<Layout title="Fees and Paid Services - Mobazha" description="How Community, Cloud, managed services, network costs, and optional distribution fees work on Mobazha.">
  <Header />
  <main class="pt-32 pb-20">
    <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[360px] w-[600px] -translate-x-1/2 -translate-y-1/3 rounded-full bg-[var(--color-brand)] opacity-[0.06] blur-[100px]"></div>
      </div>
      <div class="relative">
        <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand)]/10 px-4 py-1.5 text-sm font-semibold text-[var(--color-brand-light)]">
          {economicsPolicy.stage} policy
        </div>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
          Know what you pay — and why
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-body)]">
          Mobazha separates software, managed services, distribution, and third-party costs. There is no blanket fee that applies to every deployment or every order.
        </p>
        <p class="mt-4 text-xs text-[var(--color-text-muted)]">
          Current policy effective {economicsPolicy.effectiveDate}
        </p>
      </div>
    </div>

    <div id="community-boundary" class="mx-auto mt-16 grid max-w-6xl scroll-mt-28 gap-6 px-6 md:grid-cols-2 lg:px-8">
      {categories.map(category => (
        <article class="rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-7">
          <h2 class="text-xl font-semibold text-[var(--color-text-primary)]">{category.title}</h2>
          <p class="mt-2 text-sm font-semibold text-[var(--color-brand-light)]">{category.status}</p>
          <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-muted)]">{category.description}</p>
        </article>
      ))}
    </div>

    <section class="mx-auto mt-20 max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-brand)]/5 p-8 sm:p-10">
        <h2 class="text-2xl font-bold text-[var(--color-text-primary)]">What a fee quote should show</h2>
        <p class="mt-3 text-[var(--color-text-body)]">
          Before confirming a paid action, you should be able to see the service provider, who pays, the amount or percentage, any minimum or cap, the settlement asset, separate network or third-party costs, and what happens after cancellation, refund, or dispute.
        </p>
        <p class="mt-4 text-sm text-[var(--color-text-muted)]">
          If checkout does not disclose a new Mobazha fee before confirmation, that fee should not be silently deducted later.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-[var(--color-text-primary)]">What is not a Mobazha platform fee?</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {[
          'Blockchain gas or miner fees',
          'Payment-processor charges',
          'Server, storage, and bandwidth costs',
          'Taxes, exchange, or compliance costs',
          'Independent plugin or service pricing',
          'A seller-funded referral commission',
        ].map(item => (
          <div class="flex items-start gap-3 rounded-xl border border-white/5 bg-[var(--color-bg-surface)] p-4 text-sm text-[var(--color-text-body)]">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-4xl px-6 text-center lg:px-8">
      <p class="text-sm text-[var(--color-text-muted)]">
        Read the current
        <a class="text-[var(--color-brand-light)] hover:underline" href={economicsPolicy.communityPolicyUrl}>Community fee boundary</a>.
        The canonical repository policy will be linked here after the Community repository is public.
        For product plans, see <a class="text-[var(--color-brand-light)] hover:underline" href="/pricing">Pricing</a>.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
