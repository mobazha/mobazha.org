---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const vpsProviders = [
  { name: 'Hetzner', spec: '2 vCPU / 4 GB / 40 GB SSD', price: '~€4.5/mo', href: 'https://www.hetzner.com/cloud' },
  { name: 'DigitalOcean', spec: '2 vCPU / 4 GB / 80 GB SSD', price: '~$24/mo', href: 'https://www.digitalocean.com/pricing/droplets' },
  { name: 'Vultr', spec: '2 vCPU / 4 GB / 80 GB SSD', price: '~$24/mo', href: 'https://www.vultr.com/pricing/' },
  { name: 'Contabo', spec: '4 vCPU / 8 GB / 50 GB SSD', price: '~€6/mo', href: 'https://contabo.com/en/vps/' },
];

const nativePlatforms = [
  { os: 'Linux x86_64', cmd: 'curl -sSL https://get.mobazha.org/install | bash', note: 'Ubuntu, Debian, CentOS, etc.' },
  { os: 'Linux ARM64', cmd: 'curl -sSL https://get.mobazha.org/install | bash', note: 'Raspberry Pi 4+, ARM VPS' },
  { os: 'macOS', cmd: 'curl -sSL https://get.mobazha.org/install | bash', note: 'Apple Silicon & Intel — includes desktop tray' },
  { os: 'Windows', cmd: 'Download .zip below', note: 'x86_64 — extract and double-click mobazha-tray.exe' },
];

const features = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Complete Data Sovereignty',
    description: 'Your store data stays on your server. No one else has access.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Zero Commission',
    description: 'Keep 100% of your revenue. No platform cut on any sale.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: 'Built-in Buyer Protection',
    description: 'Built-in escrow protection on every crypto transaction. Trust from day one.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: 'Crypto + Fiat Payments',
    description: 'Bitcoin, Litecoin, Zcash, and more — plus Stripe and PayPal.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" /></svg>`,
    title: 'Run Anywhere',
    description: 'Native binary for Linux, macOS, Windows, and ARM. Or use Docker. No dependencies required.',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`,
    title: 'Encrypted Chat',
    description: 'Matrix-based end-to-end encrypted buyer-seller messaging.',
  },
];

const faqs = [
  {
    q: 'What are the minimum server requirements?',
    a: '2 CPU cores, 2 GB RAM, 20 GB SSD storage. Native binary works on Linux (x86_64/ARM64), macOS, and Windows. Docker option requires Ubuntu 22.04+ or Debian 12+.',
  },
  {
    q: 'Should I use the native binary or Docker?',
    a: '<strong>Desktop tray</strong> — available for macOS and Windows. System tray icon, auto-opens your browser. On macOS, install via the curl command (tray is included automatically). On Windows, download the .zip.<br/><strong>Native binary</strong> (CLI) — single executable, no dependencies. Best for Linux servers, ARM devices (Raspberry Pi), and power users.<br/><strong>Docker</strong> — includes automatic updates via systemd timer. Best for Linux VPS if you already use Docker.',
  },
  {
    q: 'Do I need a public IP or domain name?',
    a: 'No. Your store automatically connects to the Mobazha network, so buyers can find you through the marketplace and Telegram. A domain is optional — you can add one later for a custom store URL.',
  },
  {
    q: 'Can I run this at home instead of a VPS?',
    a: 'Yes — just install and it works, even without a static IP. Buyers reach your store through the Mobazha marketplace. Want a shareable link too? Add <code>--overlay tor</code> or <code>--overlay lokinet</code> for a direct address, or turn it on later from <strong>Admin &rarr; System &rarr; Network</strong>.',
  },
  {
    q: 'How do backups work?',
    a: 'Run <code>mobazha backup</code> to create a compressed archive of your store data. For Docker, use standard tools (rsync, restic, etc.) to back up <code>/opt/mobazha/data</code>.',
  },
  {
    q: 'Can I migrate to/from SaaS later?',
    a: 'Yes. Your store data is fully exportable. You can migrate between self-hosted and SaaS at any time.',
  },
  {
    q: 'Is this free?',
    a: 'The software is free during Beta. You only pay for your server. After Beta, self-hosted nodes will have the same zero-commission pricing — you only pay for optional premium features.',
  },
];
---

<Layout title="Self-Host Your Store - Mobazha" description="Deploy your own Mobazha store on any server with a single command. VPS or home server, with optional Tor/Lokinet privacy. Complete data ownership, zero commissions.">
  <Header />
  <main class="pt-32 pb-20">
    <!-- Hero -->
    <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-1/2 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-[var(--color-brand)] opacity-[0.06] blur-[100px]"></div>
      </div>
      <div class="relative">
        <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-brand)]/10 px-4 py-1.5 mb-6">
          <svg class="h-4 w-4 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" /></svg>
          <span class="text-sm font-semibold text-[var(--color-brand-light)]">Self-Hosted</span>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl">
          Your Server.<br />
          <span class="bg-gradient-to-r from-[var(--color-brand)] to-[var(--color-brand-light)] bg-clip-text text-transparent">
            Your Store.
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-text-body)]">
          Deploy a fully independent Mobazha store on any server with a single command.
          Cloud VPS or home server — no accounts, no platform dependencies.
          Your data never leaves your server.
        </p>
      </div>
    </div>

    <!-- Install Methods Tabs -->
    <div class="mx-auto mt-14 max-w-3xl px-6 lg:px-8">
      <!-- Tab buttons -->
      <div class="flex justify-center gap-2 mb-6">
        <button
          id="tab-native"
          class="install-tab rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors bg-[var(--color-brand)]/10 text-[var(--color-brand-light)] border border-[var(--color-brand)]/30"
          data-tab="native"
        >
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" /></svg>
            Native Binary
          </span>
        </button>
        <button
          id="tab-docker"
          class="install-tab rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors text-[var(--color-text-muted)] border border-white/10 hover:bg-white/5"
          data-tab="docker"
        >
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>
            Docker
          </span>
        </button>
      </div>

      <!-- Native panel -->
      <div id="panel-native" class="install-panel">
        <div class="rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-bg-surface)] p-1">
          <div class="flex items-center gap-3 rounded-xl bg-[var(--color-bg-base)] px-5 py-4 font-mono text-sm">
            <span class="select-none text-[var(--color-text-muted)]">$</span>
            <code id="native-cmd" class="flex-1 text-[var(--color-brand-light)] break-all">curl -sSL https://get.mobazha.org/install | bash</code>
            <button class="copy-btn shrink-0 rounded-md p-1.5 text-[var(--color-text-muted)] transition-colors hover:bg-white/5 hover:text-[var(--color-text-primary)]" data-cmd="curl -sSL https://get.mobazha.org/install | bash" aria-label="Copy command">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>
            </button>
          </div>
        </div>
        <p class="mt-3 text-center text-sm text-[var(--color-text-muted)]">
          Single binary, zero dependencies. Works on Linux (x86_64 &amp; ARM64), macOS (Apple Silicon &amp; Intel), and Windows.
        </p>

        <!-- Desktop Download (Windows only) -->
        <div class="mt-8 rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-bg-surface)] p-6 text-center">
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-1">Windows Desktop App</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-5">
            No command line needed. Download, extract, and your store opens automatically.
          </p>
          <a
            href="/download"
            class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-brand)]/10 border border-[var(--color-brand)]/30 px-6 py-3 text-sm font-semibold text-[var(--color-brand-light)] transition-colors hover:bg-[var(--color-brand)]/20"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
            Download for Windows (.zip)
          </a>
        </div>
        <!-- Platform table -->
        <div class="mt-6 overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-white/10">
                <th class="pb-3 pr-6 font-medium text-[var(--color-text-muted)]">Platform</th>
                <th class="pb-3 pr-6 font-medium text-[var(--color-text-muted)]">Install</th>
                <th class="pb-3 font-medium text-[var(--color-text-muted)]">Note</th>
              </tr>
            </thead>
            <tbody class="text-[var(--color-text-body)]">
              {nativePlatforms.map(p => (
                <tr class="border-b border-white/5">
                  <td class="py-3 pr-6 font-medium text-[var(--color-text-primary)] whitespace-nowrap">{p.os}</td>
                  <td class="py-3 pr-6 font-mono text-xs text-[var(--color-brand-light)]">
                    {p.href ? (
                      <a href={p.href} target="_blank" rel="noopener noreferrer" class="hover:underline">{p.cmd}</a>
                    ) : (
                      <span>{p.cmd}</span>
                    )}
                  </td>
                  <td class="py-3 text-xs text-[var(--color-text-muted)]">{p.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Docker panel -->
      <div id="panel-docker" class="install-panel hidden">
        <div class="rounded-2xl border border-[var(--color-brand)]/20 bg-[var(--color-bg-surface)] p-1">
          <div class="flex items-center gap-3 rounded-xl bg-[var(--color-bg-base)] px-5 py-4 font-mono text-sm">
            <span class="select-none text-[var(--color-text-muted)]">$</span>
            <code id="docker-cmd" class="flex-1 text-[var(--color-brand-light)] break-all">curl -sSL https://get.mobazha.org/standalone | sudo bash</code>
            <button class="copy-btn shrink-0 rounded-md p-1.5 text-[var(--color-text-muted)] transition-colors hover:bg-white/5 hover:text-[var(--color-text-primary)]" data-cmd="curl -sSL https://get.mobazha.org/standalone | sudo bash" aria-label="Copy command">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>
            </button>
          </div>
        </div>
        <p class="mt-3 text-center text-sm text-[var(--color-text-muted)]">
          Docker-based with automatic updates. Works on Ubuntu 22.04+, Debian 12+.
        </p>
      </div>

      <!-- AI assistant tip -->
      <p class="mt-6 text-center text-sm text-[var(--color-text-muted)]">
        <svg class="inline-block h-4 w-4 mr-1 -mt-0.5 text-[var(--color-brand-light)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
        Using an AI coding assistant? Install <a href="https://github.com/mobazha/mobazha-skills" class="text-[var(--color-brand-light)] hover:underline">Mobazha Skills</a> and let your AI deploy the store for you.
      </p>
    </div>

    <!-- What happens -->
    <div class="mx-auto mt-20 max-w-4xl px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-[var(--color-text-primary)]">
        What happens when you run the command
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        <div class="relative rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-6">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">1</div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Install</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            A single binary is downloaded to your machine. No Docker, no runtime dependencies.
            With the Docker method, images are pulled and services start automatically.
          </p>
        </div>
        <div class="relative rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-6">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">2</div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Open /admin</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Open your store URL in a browser. The Setup Wizard guides you through password, store name, and currency.
          </p>
        </div>
        <div class="relative rounded-2xl border border-white/5 bg-[var(--color-bg-surface)] p-6">
          <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-lg font-bold text-[var(--color-brand-light)]">3</div>
          <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Start Selling</h3>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">
            Add products, configure payments, and share your store link. You're live.
          </p>
        </div>
      </div>
    </div>

    <!-- Advanced Options -->
    <div class="mx-auto mt-16 max-w-3xl px-6 lg:px-8">
      <details class="group rounded-2xl border border-white/5 bg-[var(--color-bg-surface)]">
        <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-[var(--color-text-primary)] font-semibold">
          Advanced install options
          <svg class="h-5 w-5 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="border-t border-white/5 px-6 py-5 space-y-5 text-sm text-[var(--color-text-body)]">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Native binary</p>
          <div>
            <p class="font-medium text-[var(--color-text-primary)]">Start with a domain (auto-TLS via Let&rsquo;s Encrypt):</p>
            <code class="mt-1.5 block rounded-lg bg-[var(--color-bg-base)] px-4 py-2.5 font-mono text-xs text-[var(--color-brand-light)]">mobazha start --domain shop.example.com</code>
          </div>
          <div>
            <p class="font-medium text-[var(--color-text-primary)]">Install as a system service (Linux systemd / macOS launchd):</p>
            <code class="mt-1.5 block rounded-lg bg-[var(--color-bg-base)] px-4 py-2.5 font-mono text-xs text-[var(--color-brand-light)]">sudo mobazha setup-service install</code>
          </div>
          <div>
            <p class="font-medium text-[var(--color-text-primary)]">Back up your store data:</p>
            <code class="mt-1.5 block rounded-lg bg-[var(--color-bg-base)] px-4 py-2.5 font-mono text-xs text-[var(--color-brand-light)]">mobazha backup -o ~/mobazha-backup.tar.gz</code>
          </div>
          <div>
            <p class="font-medium text-[var(--color-text-primary)]">Uninstall (removes binary &amp; service, keeps data):</p>
            <code class="mt-1.5 block rounded-lg bg-[var(--color-bg-base)] px-4 py-2.5 font-mono text-xs text-[var(--color-brand-light)]">curl -sSL https://get.mobazha.org/install | bash -s -- --uninstall</code>
            <p class="mt-1 text-xs text-[var(--color-text-muted)]">Add <code>--purge</code> to also remove data. Run <code>--help</code> for all options.</p>
          </div>
