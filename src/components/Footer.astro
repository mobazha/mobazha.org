---
const links = {
  Product: [
    { label: 'Features', href: '/#features' },
    { label: 'Pricing', href: '/pricing' },
    { label: 'For Sellers', href: '/sellers' },
    { label: 'Mini App', href: 'https://t.me/MobazhaBot' },
  ],
  Resources: [
    { label: 'Blog', href: '/blog' },
    { label: 'Documentation', href: 'https://docs.mobazha.org' },
    { label: 'API Reference', href: 'https://docs.mobazha.org/api' },
    { label: 'Status', href: 'https://status.mobazha.org' },
  ],
  Community: [
    { label: 'Telegram', href: 'https://t.me/mobazha' },
    { label: 'Twitter / X', href: 'https://x.com/mobazha' },
    { label: 'GitHub', href: 'https://github.com/mobazha' },
  ],
};
---

<footer class="border-t border-white/5 bg-[var(--color-bg-base)]">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2.5">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-light)]">
            <span class="text-sm font-bold text-white">M</span>
          </div>
          <span class="text-lg font-semibold text-[var(--color-text-primary)]">Mobazha</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
          Decentralized commerce for independent sellers. Zero commissions. Your data, your rules.
        </p>
      </div>

      <!-- Link columns -->
      {Object.entries(links).map(([title, items]) => (
        <div>
          <h4 class="text-sm font-semibold text-[var(--color-text-primary)]">{title}</h4>
          <ul class="mt-3 space-y-2.5">
            {items.map(item => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-body)]"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 sm:flex-row">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} Mobazha. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="https://t.me/mobazha" class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-body)]" aria-label="Telegram">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>
        <a href="https://x.com/mobazha" class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-body)]" aria-label="Twitter / X">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://github.com/mobazha" class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-body)]" aria-label="GitHub">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
