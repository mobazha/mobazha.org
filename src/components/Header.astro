---
const navLinks = [
  { href: '/#features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/sellers', label: 'For Sellers' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-xl bg-[var(--color-bg-base)]/80">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <a href="/" class="flex items-center gap-2.5">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-light)]">
        <span class="text-sm font-bold text-white">M</span>
      </div>
      <span class="text-lg font-semibold text-[var(--color-text-primary)]">Mobazha</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text-primary)]"
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://app.mobazha.org"
        class="hidden rounded-lg px-4 py-2 text-sm font-medium text-[var(--color-text-body)] transition-colors hover:text-[var(--color-text-primary)] sm:block"
      >
        Sign In
      </a>
      <a
        href="https://app.mobazha.org"
        class="rounded-lg bg-[var(--color-cta)] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-cta-hover)]"
      >
        Create Your Store
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="flex items-center justify-center md:hidden"
      aria-label="Toggle menu"
    >
      <svg class="h-6 w-6 text-[var(--color-text-body)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/5 md:hidden">
    <div class="space-y-1 px-6 py-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-bg-surface)] hover:text-[var(--color-text-primary)]"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://app.mobazha.org"
        class="block rounded-lg px-3 py-2 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-bg-surface)] hover:text-[var(--color-text-primary)]"
      >
        Sign In
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
