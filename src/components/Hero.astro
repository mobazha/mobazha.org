<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <!-- Background: radial gradient + dot pattern -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-1/2 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/4 rounded-full bg-[var(--color-brand)] opacity-[0.07] blur-[120px]"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, var(--color-text-muted) 1px, transparent 1px); background-size: 24px 24px;"></div>
  </div>

  <div class="relative mx-auto max-w-5xl px-6 text-center lg:px-8">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-brand)]/20 bg-[var(--color-brand)]/10 px-4 py-1.5">
      <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand-light)]"></span>
      <span class="text-xs font-medium tracking-wide text-[var(--color-brand-light)] uppercase">
        Decentralized Commerce Platform
      </span>
    </div>

    <!-- Headline -->
    <h1 class="mx-auto max-w-4xl text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl lg:text-6xl">
      Sell Without Middlemen.<br />
      <span class="bg-gradient-to-r from-[var(--color-brand)] to-[var(--color-brand-light)] bg-clip-text text-transparent">
        Get Paid Instantly.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-text-body)] sm:text-xl">
      Create your own store in 30 seconds. Accept crypto & fiat payments.
      Your data, your rules.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://app.mobazha.org"
        class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-cta)] px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-[var(--color-cta)]/25 transition-all hover:bg-[var(--color-cta-hover)] hover:shadow-xl hover:shadow-[var(--color-cta)]/30"
      >
        Create Your Store
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="https://app.mobazha.org"
        class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-7 py-3.5 text-base font-medium text-[var(--color-text-primary)] transition-all hover:border-white/20 hover:bg-white/10"
      >
        Explore Stores
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
