<section class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-[var(--color-text-primary)] sm:text-4xl">
        Open your store in 3 steps
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-body)]">
        From zero to live store — no technical skills required.
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-4xl gap-8 sm:grid-cols-3">
      <div class="relative text-center">
        <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-xl font-bold text-[var(--color-brand-light)]">1</div>
        <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Create your store</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
          Sign up, pick a name, and choose your currency. Done in 30 seconds — or self-host on your own server.
        </p>
        <div class="absolute top-6 left-[calc(50%+2rem)] hidden h-px w-[calc(100%-4rem)] bg-gradient-to-r from-[var(--color-brand)]/30 to-transparent sm:block"></div>
      </div>

      <div class="relative text-center">
        <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-xl font-bold text-[var(--color-brand-light)]">2</div>
        <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Add products</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
          List your products with photos, pricing, and shipping options. AI can help write descriptions.
        </p>
        <div class="absolute top-6 left-[calc(50%+2rem)] hidden h-px w-[calc(100%-4rem)] bg-gradient-to-r from-[var(--color-brand)]/30 to-transparent sm:block"></div>
      </div>

      <div class="text-center">
        <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-brand)]/10 text-xl font-bold text-[var(--color-brand-light)]">3</div>
        <h3 class="text-lg font-semibold text-[var(--color-text-primary)]">Share inside Telegram</h3>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
          Your store opens as a <strong class="text-[var(--color-text-primary)]">Telegram Mini App</strong>. Drop the link in any chat, group, or channel &mdash; buyers check out without leaving the app.
        </p>
      </div>
    </div>
  </div>
</section>
